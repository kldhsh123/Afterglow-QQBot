# 复制为 .env 并填入凭据

# ===== QQ 机器人凭据（https://q.qq.com 应用管理） =====
QQ_BOT_APP_ID=your_app_id_here
QQ_BOT_CLIENT_SECRET=your_client_secret_here

# ===== Afterglow 后端 =====
# 默认本地启动地址
AFTERGLOW_BASE_URL=http://127.0.0.1:8000
# 与 Afterglow backend/.env 中的 XUWEN_API_KEY 一致
AFTERGLOW_API_KEY=your_xuwen_api_key_here
# 占位，实际由 Afterglow 后端 CHAT_MODEL 决定
AFTERGLOW_MODEL=afterglow
# 单次请求超时（秒），检索+生成可能较慢
AFTERGLOW_TIMEOUT=120
# 沉默 sentinel，与后端 SILENCE_RESPONSE_SENTINEL 保持一致（默认 [silent]）
AFTERGLOW_SILENCE_SENTINEL=[silent]
# 客户端在 messages 数组里携带的最近轮数（一轮 = user+assistant）
# 让后端拿到直接上下文，不必只靠 conversation_id 检索。0 表示不携带
AFTERGLOW_HISTORY_MAX_TURNS=6
# 调用 Afterglow 失败时发给用户的兜底文本；留空则不回复（更接近真人"没动静"）
AFTERGLOW_ERROR_REPLY=

# ===== 用户白名单 =====
# 逗号分隔的 user_openid 列表；留空 = 不启用白名单（任何 QQ 用户都能触发 Afterglow）
# 启用方式：先留空启动，让目标用户发一条消息，从日志里找到 "openid=xxx"，
# 把 xxx 填进来重启即可。多个用 , 分隔。
AFTERGLOW_ALLOWED_OPENIDS=6295AC21535952E005B6EB5F21703CF2
# 非白名单用户的回复文本；留空 = 静默丢弃（不暴露机器人存在）
AFTERGLOW_DENIED_REPLY=

# ===== 日志 =====
# DEBUG / INFO / WARNING
LOG_LEVEL=INFO
